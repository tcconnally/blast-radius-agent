# Environment Configuration
# Copy this file to .env and fill in values
# Do NOT commit .env to version control

# GitLab instance URL (default: gitlab.com)
GITLAB_URL=https://gitlab.com

# GitLab personal access token with api scope
# Create at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# Orbit mode: "remote" (requires Premium/Ultimate) or "local" (uses CLI)
ORBIT_MODE=local

# Path to Orbit CLI binary (local mode only)
ORBIT_CLI_PATH=orbit

# Maximum traversal depth for transitive dependency analysis
BLAST_RADIUS_MAX_DEPTH=3

# Risk thresholds
RISK_LOW_THRESHOLD=2
RISK_MEDIUM_THRESHOLD=10
RISK_HIGH_THRESHOLD=50

# Exclude patterns (comma-separated)
EXCLUDE_PATTERNS=*test*,*spec*,*.generated.*,__generated__/*,node_modules/*,.venv/*
